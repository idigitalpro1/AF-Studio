{
  "entities": {
    "Creation": {
      "title": "Creation",
      "description": "An art creation generated by the user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created this art."
        },
        "type": {
          "type": "string",
          "enum": ["image", "video", "magazine"],
          "description": "The type of creation."
        },
        "dataUrl": {
          "type": "string",
          "description": "The base64 data URL of the creation."
        },
        "prompt": {
          "type": "string",
          "description": "The prompt used to generate the creation."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the creation was saved."
        }
      },
      "required": ["userId", "type", "dataUrl", "createdAt"]
    }
  },
  "firestore": {
    "/creations/{creationId}": {
      "schema": {
        "$ref": "#/entities/Creation"
      },
      "description": "Stores user art creations."
    }
  }
}
