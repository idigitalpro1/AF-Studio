rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /creations/{creationId} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null &&
                    request.resource.data.keys().hasOnly(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'stars', 'comments', 'commentsList']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.userId is string &&
                    request.resource.data.type in ['image', 'video', 'magazine'] &&
                    request.resource.data.dataUrl is string &&
                    (!('prompt' in request.resource.data) || request.resource.data.prompt is string) &&
                    (!('stars' in request.resource.data) || request.resource.data.stars is int) &&
                    request.resource.data.createdAt is timestamp;
                    
      allow update: if request.auth != null && (
        // Case 1: Owner updating general fields (must not modify stars)
        (request.auth.uid == resource.data.userId &&
         request.resource.data.keys().hasOnly(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'stars', 'comments', 'commentsList']) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'createdAt', 'stars'])) ||
        
        // Case 2: Any authenticated user rating/favoriting (can ONLY change stars count by +1 or -1 atomically)
        (
         request.resource.data.keys().hasOnly(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'stars', 'comments', 'commentsList']) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'comments', 'commentsList']) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars']) &&
         (
           (request.resource.data.stars == resource.data.stars + 1 &&
            existsAfter(/databases/$(database)/documents/likes/$(request.auth.uid + '_' + creationId))) ||
           
           (request.resource.data.stars == resource.data.stars - 1 &&
            !existsAfter(/databases/$(database)/documents/likes/$(request.auth.uid + '_' + creationId)))
         )
        ) ||

        // Case 3: Any authenticated user commenting (can only modify comments and commentsList)
        (
         request.resource.data.keys().hasOnly(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'stars', 'comments', 'commentsList']) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'type', 'dataUrl', 'prompt', 'createdAt', 'stars'])
        )
      );
      
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /likes/{likeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow create: if request.auth != null &&
                    likeId == request.auth.uid + "_" + request.resource.data.creationId &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.creationId is string &&
                    request.resource.data.createdAt is timestamp &&
                    exists(/databases/$(database)/documents/creations/$(request.resource.data.creationId));
                    
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
