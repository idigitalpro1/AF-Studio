rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: creations
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The ID of the user who created this art
    //   - type: string (required) - 'image', 'video', 'magazine'
    //   - dataUrl: string (required) - The base64 data URL
    //   - prompt: string (optional) - The prompt used
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validators
    function isValidCreation(data) {
      return hasOnlyAllowedFields(['userId', 'type', 'dataUrl', 'prompt', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 128 &&
             data.type in ['image', 'video', 'magazine'] &&
             data.dataUrl is string && data.dataUrl.size() > 0 && data.dataUrl.size() < 1000000 &&
             (!('prompt' in data) || (data.prompt is string && data.prompt.size() < 5000)) &&
             data.createdAt is timestamp;
    }

    match /creations/{creationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    isValidCreation(request.resource.data) &&
                    request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() &&
                    isValidCreation(request.resource.data) &&
                    areImmutableFieldsUnchanged(['userId', 'createdAt']);
      allow delete: if isDocOwner();
    }
  }
}
